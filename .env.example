# ─────────────────────────────────────────────────────────────────────────────
# EventFlow - Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
#
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control. It is in .gitignore.
#
# To generate a strong JWT_SECRET value, run :
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#
# ─────────────────────────────────────────────────────────────────────────────


# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED
# ─────────────────────────────────────────────────────────────────────────────

# Secret key used to sign and verify JWT tokens.
# Use a random string of at least 64 characters.
# If this value changes, all existing sessions become invalid.
JWT_SECRET=replace-this-with-a-long-random-string


# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL - JWT CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────

# How long a JWT token remains valid after login.
# Uses the ms library format : "7d", "24h", "60m", "30s"
# Default : 7d
JWT_EXPIRES_IN=7d


# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL - RATE LIMITING
# ─────────────────────────────────────────────────────────────────────────────

# Time window for rate limiting, in milliseconds.
# Default : 900000 (15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# Maximum number of login attempts allowed per IP per window.
# Default : 10
RATE_LIMIT_MAX=10


# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL - NODE
# ─────────────────────────────────────────────────────────────────────────────

# Set to "production" when deploying.
# This enables Secure and SameSite=Strict flags on the session cookie.
# Default : development
NODE_ENV=development
